{
  "orchestrator_class": "DirectLLMResponse",
  "processor_config": {
    "OpenEdXProcessor": {
    },
    "LLMProcessor": {
      "function": "answer_question",
      "config": "openai",
      "tools_enabled": [
        "get_location_content",
        "roll_dice"
      ],
      "extra_context": {
        "vars_to_include_in_context": [
          "location_id"
        ]
      }
    }
  },
  "actuator_config": {
    "UIComponents": {
      "request": {
        "component": "AIRequestComponent",
        "config": {
          "buttonText": "Ask AI [config api]",
          "customMessage": "Openai will call a function"
        }
      },
      "response": {
        "component": "AIResponseComponent",
        "config": {
          "customMessage": "AI Assistant Response [config api]"
        }
      },
      "metadata": {
          "version": 0.1,
          "provider": "config_api"
      }
    }
  }
}
